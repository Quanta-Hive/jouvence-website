generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           UserRole @default(EDITOR)
  posts          BlogPost[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PartyMember {
  id          String   @id @default(cuid())
  name        String
  photoUrl    String?
  email       String?
  facebookUrl String?
  twitterUrl  String?
  linkedinUrl String?
  isLeader    Boolean  @default(false)
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  roleFr      String
  roleEn      String
  bioFr       String   @default("")
  bioEn       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([isLeader])
}

model BlogPost {
  id           String     @id @default(cuid())
  slugFr       String     @unique
  slugEn       String     @unique
  titleFr      String
  titleEn      String
  excerptFr    String     @default("")
  excerptEn    String     @default("")
  bodyFr       String     @default("")
  bodyEn       String     @default("")
  coverImage   String?
  category     String     @default("Actualité")
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?
  author       User       @relation(fields: [authorId], references: [id])
  authorId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status, publishedAt])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  photoUrl    String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  roleFr      String
  roleEn      String
  quoteFr     String
  quoteEn     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model MembershipApplication {
  id          String            @id @default(cuid())
  fullName    String
  birthDate   DateTime
  email       String
  phone       String
  region      String
  city        String
  profession  String?
  motivation  String?
  documentUrl String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  @@index([status, createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("fr")
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
